<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 상단 바 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:src="@drawable/logo"
            android:contentDescription="Logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profileImage"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="24dp"
            android:src="@drawable/sample_profile"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0.5" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/nutrient_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <FrameLayout
            android:layout_width="364dp"
            android:layout_height="157dp"
            android:layout_gravity="left"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="29dp"
            android:background="@color/white">

            <TextView
                android:id="@+id/textView4"
                android:layout_width="44.22dp"
                android:layout_gravity="top"
                android:layout_marginTop="39.25dp"
                android:layout_height="16dp"
                android:text="KCAL" />

            <TextView
                android:id="@+id/summaryTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:textSize="16sp"
                android:text="오늘의 총 섭취 영양소"
                android:textColor="#000000" />


            <TextView
                android:id="@+id/textView7"
                android:layout_width="87dp"
                android:layout_height="30dp"
                android:layout_marginLeft="56dp"
                android:layout_gravity="top"
                android:layout_marginTop="33.25dp"
                android:gravity="center|left"
                android:text="1,620Kcal"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textView5"
                android:layout_width="44dp"
                android:layout_height="19dp"
                android:layout_gravity="bottom"
                android:layout_marginBottom="39.25dp"
                android:gravity="center|left"
                android:text="단백질" />

            <TextView
                android:id="@+id/textViewt5"
                android:layout_width="55dp"
                android:layout_height="19dp"
                android:layout_gravity="top"
                android:layout_marginTop="39.25dp"
                android:layout_marginLeft="174dp"
                android:gravity="center|left"
                android:text="탄수화물" />

            <TextView
                android:id="@+id/textView6"
                android:layout_width="28dp"
                android:layout_height="19dp"
                android:layout_gravity="bottom"
                android:layout_marginBottom="39.25dp"
                android:layout_marginLeft="174dp"
                android:gravity="center|left"
                android:text="지방" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@android:color/white"
            android:elevation="4dp">

            <CalendarView
                android:id="@+id/calendarView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"/>
        </FrameLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>